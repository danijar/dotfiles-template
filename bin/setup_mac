#!/usr/bash

# Run this script from anywhere:
# sudo curl -fsSL https://tinyurl.com/setupmac1 | bash

set -euo pipefail
trap 'echo "Script errored at line $LINENO"' ERR

# Homebrew
if ! command -v brew &>/dev/null; then
  /usr/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  eval "$(/opt/homebrew/bin/brew shellenv)"
  export PATH="/opt/homebrew/bin:$PATH"
fi

# Apps
brew install --cask google-chrome
brew install --cask gimp

# Terminal
brew install alacritty

# Window manager
brew install --cask nikitabobko/tap/aerospace

# Tools
brew install neovim
brew install gh
brew install uv
brew install ripgrep
brew install tmux
brew install htop
brew install coreutils
brew install wget
brew install ffmpeg
brew install git-delta
brew install claude-code
brew install tree

# Python
uv python install 3.14
if [ ! -d ~/.venv ]; then
  uv venv ~/.venv --python 3.14
fi
source ~/.venv/bin/activate
uv pip install numpy mediapy

# Folders
mkdir -p ~/repo
mkdir -p ~/temp

# Dotfiles
cd ~/repo
if [ ! -d ~/repo/dotfiles ]; then
  git clone https://github.com/danijar/dotfiles-template.git dotfiles
fi
cd dotfiles
git pull
python3 symlink.py
cd ~

# Hide dock
defaults write com.apple.dock orientation -string "left"
defaults write com.apple.dock autohide -bool true
defaults write com.apple.dock tilesize -int 16
killall Dock

# Opaque menu bar
defaults write NSGlobalDomain SLSMenuBarUseBlurredAppearance -bool true

# Disable hot corners
for corner in tl tr bl br; do
  defaults write com.apple.dock wvous-${corner}-corner -int 0
  defaults write com.apple.dock wvous-${corner}-modifier -int 0
  defaults write com.apple.MissionControl wvous-${corner}-corner -int 0
  defaults write com.apple.MissionControl wvous-${corner}-modifier -int 0
done
killall Dock

# Reduce animations
defaults write NSGlobalDomain NSAutomaticWindowAnimationsEnabled -bool false
defaults write NSGlobalDomain NSWindowResizeTime -float 0.001
killall Dock

# Disable desktop click
defaults write com.apple.WindowManager EnableStandardClickToShowDesktop -bool false
killall Dock

# Disable double space for period
defaults write -g NSAutomaticPeriodSubstitutionEnabled -bool false

# Disable swipe to navigate backward (restart Chrome after)
defaults write NSGlobalDomain AppleEnableSwipeNavigateWithScrolls -bool false

# Keyboard shortcuts
defaults write NSGlobalDomain NSUserKeyEquivalents -dict-add "Lock Screen" '~^l'
hotkey() {
  defaults write com.apple.symbolichotkeys AppleSymbolicHotKeys \
    -dict-add "$1" "{enabled=$2;value={parameters=($3);type=standard;};}"
}
hotkey 31 1 "49,18,1048576"   # Cmd+1: Copy selected area to clipboard
hotkey 29 1 "50,19,1048576"   # Cmd+2: Copy screen to clipboard
hotkey 30 1 "51,20,1048576"   # Cmd+3: Save selected area as file
hotkey 28 1 "52,21,1048576"   # Cmd+4: Save screen as file
hotkey 184 1 "53,23,1048576"  # Cmd+5: Screenshot and recording options

# Manual steps
# - Remap modifier keys (for each keyboard): Caps->Cmd, Opt<->Cmd
# - Start Aerospace
# - Login to Chrome
# - Login to Github CLI: gh auth login
